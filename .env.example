# ─── Vision provider ─────────────────────────────────────────────────────────
# "auto" uses Gemini (free) when GEMINI_API_KEY is set below, else Claude.
# Force one with "claude" or "gemini".
VISION_PROVIDER=auto

# ─── Gemini (FREE — preferred) ───────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── OpenAI-compatible (FREE alt — OpenRouter / GitHub Models / Groq / ...) ───
# Set VISION_PROVIDER=openai to use this. OpenRouter key: https://openrouter.ai/keys
# Models are tried in order and rotate on quota/overload.
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPAT_MODELS=meta-llama/llama-3.2-11b-vision-instruct:free,google/gemini-2.0-flash-exp:free

# ─── Claude (paid, highest accuracy) ─────────────────────────────────────────
# Create a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
MODEL_ID=claude-opus-4-8
IDENTIFY_EFFORT=high

# ─── Google Books (enrichment / grounding) ───────────────────────────────────
# Optional. Google Books works keyless at a lower quota; app-restricted keys may
# 4xx/5xx from a server, in which case the code falls back to keyless + Open Library.
GOOGLE_BOOKS_API_KEY=

# ─── Cover detection ─────────────────────────────────────────────────────────
# Optional YOLO book-cover detector (AGPL-3.0). Off by default; OpenCV contour
# detection + full-frame fallback are always available.
YOLO_BOOK_COVER_ENABLED=0
YOLO_BOOK_MODEL=

# ─── Diagnostics ─────────────────────────────────────────────────────────────
DIAGNOSTICS_DIR=./_diagnostics
DIAGNOSTICS_SAVE_CROPS=1

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
